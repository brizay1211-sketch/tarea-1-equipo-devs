{
    "compilerOptions": {
        "target": "ES2020",
        "module": "ES2020",
        "moduleResolution": "node",
        "outDir": "./js",
        "rootDir": "./",
        "strict": true,
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        "sourceMap": true,          // <-- Agrega esta línea
        "removeComments": false
    },
    "include": [
        "clases/*.ts",
        "*.ts"
    ],
    "exclude": [
        "node_modules"
    ]
}